rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Checks Firestore for the caller's role (costs 1 read per rule evaluation)
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isCurrentUser(uid) {
      return request.auth.uid == uid;
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user can read the user list (needed for staff page)
      allow read: if isSignedIn();

      // Only the user themselves can create their own profile (on registration)
      allow create: if isSignedIn() && isCurrentUser(userId);

      // User can update their own profile, but NOT the role field
      // Admin can update anyone's profile including role
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          isCurrentUser(userId) &&
          !('role' in request.resource.data.diff(resource.data).affectedKeys())
        )
      );

      // Only admin can delete user records
      allow delete: if isAdmin();
    }

    // ── Meta (used for first-user detection during registration) ───────────────
    match /_meta/{docId} {
      allow read: if isSignedIn();
      // Allow first registration to create this document
      allow create: if isSignedIn();
      // Only admin can update or delete meta (prevents tampering)
      allow update, delete: if isAdmin();
    }

    // ── Rooms ──────────────────────────────────────────────────────────────────
    match /rooms/{roomId} {
      allow read, write: if isSignedIn();
    }

    // ── Beds ───────────────────────────────────────────────────────────────────
    match /beds/{bedId} {
      allow read, write: if isSignedIn();
    }

    // ── Customers ──────────────────────────────────────────────────────────────
    match /customers/{customerId} {
      allow read, write: if isSignedIn();
    }

    // ── Bookings ───────────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow read, write: if isSignedIn();
    }

    // ── Transactions ───────────────────────────────────────────────────────────
    match /transactions/{transactionId} {
      allow read, write: if isSignedIn();
    }

    // ── Properties (admin-only write) ──────────────────────────────────────────
    match /properties/{propertyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Units ──────────────────────────────────────────────────────────────────
    match /units/{unitId} {
      allow read, write: if isSignedIn();
    }

    // ── Leases ─────────────────────────────────────────────────────────────────
    match /leases/{leaseId} {
      allow read, write: if isSignedIn();
    }

    // ── Expenses ───────────────────────────────────────────────────────────────
    match /expenses/{expenseId} {
      allow read, write: if isSignedIn();
    }

    // ── Maintenance ────────────────────────────────────────────────────────────
    match /maintenance/{requestId} {
      allow read, write: if isSignedIn();
    }
  }
}
